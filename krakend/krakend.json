{
    "version": 3,
    "name": "Clinic Hub API Gateway",
    "port": 8080,
    "timeout": "3000ms",
    "cache_ttl": "300s",
    "output_encoding": "json",
    "extra_config": {},
    "endpoints": [
        {
            "endpoint": "/health",
            "method": "GET",
            "backend": [
                {
                    "url_pattern": "/",
                    "host": [
                        "http://keycloak:8080"
                    ],
                    "encoding": "no-op",
                    "extra_config": {
                        "modifier/response-body": {
                            "type": "inline",
                            "content": "{\"health\":\"ok\"}"
                        }
                    }
                }
            ]
        },
        {
            "endpoint": "/api/users",
            "method": "GET",
            "extra_config": {
                "auth/validator": {
                    "alg": "RS256",
                    "jwk_url": "http://keycloak:8080/realms/clinic-mouzaia-hub/protocol/openid-connect/certs",
                    "cache": true,
                    "disable_jwk_security": true
                }
            },
            "backend": [
                {
                    "url_pattern": "/admin/realms/clinic-mouzaia-hub/users",
                    "host": [
                        "http://keycloak:8080"
                    ],
                    "encoding": "json",
                    "extra_config": {
                        "auth/client-credentials": {
                            "client_id": "krakend-gateway",
                            "client_secret": "RLNH2Y731jI8EKOiXwhgAk6Nh3hKUWzn",
                            "token_url": "http://keycloak:8080/realms/clinic-mouzaia-hub/protocol/openid-connect/token"
                        }
                    }
                }
            ]
        }
    ]
}